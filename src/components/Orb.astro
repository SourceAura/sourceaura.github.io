---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"petals">;
  type?: "text" | "audio" | "video" | "photo" | "project";

  width?: number;
  height?: number;

  sphereRad?: number;
  radiusSp?: number;
  projectionScale?: number;

  maxParticles?: number;
  particlesPerFrame?: number;

  particleRad?: number;

  turnSpeed?: number;

  materialStrength?: number;
  gammaDark?: number;

  lockRatio?: number;
  driftVelocity?: number;
  driftJitter?: number;
  gravity?: number;
  damping?: number;

  nearPlaneEpsilon?: number;
}

const {
  post,
  width = 720,
  height = 416,

  sphereRad = 105,
  radiusSp = 1,
  projectionScale = 0.86,

  particlesPerFrame = 9,
  maxParticles = 4800,
  lockRatio = 0.72,
  driftVelocity = 0.15,
  driftJitter = 0.25,
  particleRad = 2.2,

  turnSpeed = (2 * Math.PI) / 1200,

  materialStrength = 1.1,
  gammaDark = 0.86,

  gravity = 0,
  damping = 0.985,

  nearPlaneEpsilon = 24,
} = Astro.props;

/* Extract first markdown image */
let imageSrc: string | null = null;
const match = post.body.match(/!\[.*?\]\((.*?)\)/);
if (match?.[1]) {
  const raw = match[1].trim();
  imageSrc =
    raw.startsWith("http") || raw.startsWith("/")
      ? raw
      : `/images/${raw.replace(/^\.?\//, "")}`;
}

const uid = `orb_${Math.random().toString(16).slice(2)}`;
const canvasId = `${uid}_canvas`;
const cap = Math.max(1, Math.min(width, height));
---

<div class="ps-wrap" data-ps-root={uid} style={`max-width:${cap}px;`}>
  <canvas id={canvasId}></canvas>
</div>

<script
  is:inline
  define:vars={{
    uid,
    canvasId,
    sphereRad,
    radiusSp,
    projectionScale,
    maxParticles,
    particlesPerFrame,
    particleRad,
    turnSpeed,
    imageSrc,
    materialStrength,
    gammaDark,
    lockRatio,
    driftVelocity,
    driftJitter,
    gravity,
    damping,
    nearPlaneEpsilon,
  }}
>
  (() => {
    window.__orbMounted ??= new Set();
    if (window.__orbMounted.has(uid)) return;
    window.__orbMounted.add(uid);

    const canvas = document.getElementById(canvasId);
    const ctx = canvas?.getContext("2d");
    const wrap = document.querySelector(`[data-ps-root="${uid}"]`);

    if (!canvas || !ctx || !wrap) return;

    const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

    // ---------- Pulse (from CSS var --pulse) ----------
    // Sampling the CSS var ~10Hz avoids expensive getComputedStyle per frame.
    let pulse = 0.5;
    const samplePulse = () => {
      const v = getComputedStyle(document.documentElement).getPropertyValue(
        "--pulse",
      );
      const p = Number(v);
      pulse = Number.isFinite(p) ? Math.max(0, Math.min(1, p)) : 0.5;
    };
    samplePulse();
    const pulseTimer = setInterval(samplePulse, 120);

    function getPulse() {
      return pulse;
    }

    let lastPulse = getPulse();

    // ---------- Identify which carousel item this orb belongs to ----------
    const hostItem = wrap.closest?.(".carousel-item");
    const orbIndex = hostItem ? Number(hostItem.dataset.index) : -1;

    // ---------- Disintegration state ----------
    let dis = {
      active: false,
      level: 0,
      t0: 0,
      dur: 520, // match your scanner pulse timing
      which: "left",
      mode: "out", // "out" => disintegrate, "in" => re-form (optional)
    };

    function disLevel(now) {
      if (!dis.active) return dis.level;
      const t = (now - dis.t0) / dis.dur;
      if (t >= 1) {
        dis.active = false;
        dis.level = dis.mode === "out" ? 1 : 0;
        return dis.level;
      }
      // smooth fade curve
      const s = t * t * (3 - 2 * t);
      dis.level = dis.mode === "out" ? s : 1 - s;
      return dis.level;
    }

    // Listen for scanner pulses coming from Nelumbo
    function onScan(ev) {
      const d = ev?.detail;
      if (!d) return;
      if (orbIndex < 0 || d.index !== orbIndex) return;

      dis.active = true;
      dis.t0 = performance.now();
      dis.which = d.which;
      dis.mode = d.mode === "in" ? "in" : "out";

      for (let k = 0; k < Math.min(N, 900); k++) locked[k] = 0;
    }

    window.addEventListener("nelumbo:scan", onScan);

    // ---------- Visibility (perf) ----------
    // When the carousel item is hidden/faded, we can throttle drawing.
    let lastVisCheck = 0;
    let visScore = 1;
    function updateVisibilityScore(now) {
      if (now - lastVisCheck < 180) return;
      lastVisCheck = now;

      if (!hostItem) {
        visScore = 1;
        return;
      }

      const st = getComputedStyle(hostItem);
      if (st.visibility === "hidden" || st.display === "none") {
        visScore = 0;
        return;
      }
      const op = Number(st.opacity);
      visScore = Number.isFinite(op) ? op : 1;

      // Adaptive quality: when an item is mostly faded, reduce internal resolution.
      const nextCap = visScore < 0.05 ? 2 : 4;
      if (nextCap !== dprCap) {
        dprCap = nextCap;
        resizeToLayoutSquare();
      }
    }

    // ---------- Theme cache ----------
    let cachedMode = "source-over";
    let isDark = false;
    let fallbackRGB = "0,0,0";

    function refreshRenderStyle() {
      const rootStyle = getComputedStyle(document.documentElement);
      const wrapStyle = getComputedStyle(wrap);

      const c = wrapStyle.color;
      const m = c.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/i);
      fallbackRGB = m ? `${m[1]},${m[2]},${m[3]}` : "0,0,0";

      cachedMode =
        rootStyle.getPropertyValue("--ps-composite-mode").trim() ||
        "source-over";
      isDark = document.documentElement.classList.contains("dark");
    }

    refreshRenderStyle();
    const moTheme = new MutationObserver(refreshRenderStyle);
    moTheme.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class", "style"],
    });

    // ---------- Texture ----------
    let texReady = false;
    let texW = 0,
      texH = 0;
    let texData = null;

    function loadTexture(src) {
      if (!src) return;
      const img = new Image();
      img.crossOrigin = "anonymous";
      img.decoding = "async";
      img.loading = "eager";
      img.src = src;

      img.onload = () => {
        const maxDim = 340;
        const scale = Math.min(
          1,
          maxDim / Math.max(img.naturalWidth, img.naturalHeight),
        );
        texW = Math.max(1, Math.floor(img.naturalWidth * scale));
        texH = Math.max(1, Math.floor(img.naturalHeight * scale));

        const tcan = document.createElement("canvas");
        tcan.width = texW;
        tcan.height = texH;
        const tctx = tcan.getContext("2d", { willReadFrequently: true });
        if (!tctx) return;

        tctx.drawImage(img, 0, 0, texW, texH);
        texData = tctx.getImageData(0, 0, texW, texH).data;
        texReady = true;
      };

      img.onerror = () => {
        texReady = false;
        texData = null;
      };
    }

    loadTexture(imageSrc);

    function sampleTexture(u, v) {
      if (!texReady || !texData) return null;

      u = u - Math.floor(u);
      v = v < 0 ? 0 : v > 1 ? 1 : v;

      const x = Math.floor(u * (texW - 1));
      const y = Math.floor(v * (texH - 1));
      const idx = (y * texW + x) * 4;

      let r = texData[idx];
      let g = texData[idx + 1];
      let b = texData[idx + 2];
      const a = texData[idx + 3] / 255;

      if (isDark && gammaDark !== 1) {
        const inv = 1 / 255;
        r = Math.round(255 * Math.pow(r * inv, gammaDark));
        g = Math.round(255 * Math.pow(g * inv, gammaDark));
        b = Math.round(255 * Math.pow(b * inv, gammaDark));
      }

      return { r, g, b, a };
    }

    // ---------- Square sizing (IMPORTANT: measure layout size, not transformed rect) ----------
    let S = 256;
    let dpr = 1;
    let dprCap = 4;
    let W = 256,
      H = 256;

    function resizeToLayoutSquare() {
      // offsetWidth/clientWidth are NOT affected by 3D transforms
      const cssW = Math.max(1, wrap.clientWidth || wrap.offsetWidth || 1);
      const cssH = Math.max(1, wrap.clientHeight || wrap.offsetHeight || 1);

      S = Math.floor(Math.min(cssW, cssH));
      dpr = Math.max(1, Math.min(dprCap, window.devicePixelRatio || 1));

      const px = Math.floor(S * dpr);

      if (canvas.width !== px || canvas.height !== px) {
        canvas.width = px;
        canvas.height = px;
      }

      W = S;
      H = S;
    }

    const ro = new ResizeObserver(resizeToLayoutSquare);
    ro.observe(wrap);
    resizeToLayoutSquare();

    // ---------- Projection ----------
    const fLen = 320;
    const zMax = fLen - 2;
    const sphereCenterZ = () => -3 - sphereRad;

    // ---------- Particle pool ----------
    const N = Math.max(1, maxParticles | 0);

    const x = new Float32Array(N);
    const y = new Float32Array(N);
    const z = new Float32Array(N);

    const vx = new Float32Array(N);
    const vy = new Float32Array(N);
    const vz = new Float32Array(N);

    const theta = new Float32Array(N);
    const phi = new Float32Array(N);

    const age = new Uint16Array(N);
    const stuck = new Uint16Array(N);
    const locked = new Uint8Array(N);
    const alive = new Uint8Array(N);

    const dissolve = new Float32Array(N);

    let writeIndex = 0;

    function randn() {
      return Math.random() * 2 - 1;
    }

    function resetParticle(i) {
      // random point on sphere surface
      const th = Math.random() * Math.PI * 2;
      const ph = Math.acos(Math.random() * 2 - 1);

      theta[i] = th;
      phi[i] = ph;

      const s = Math.sin(ph);
      const nx = s * Math.cos(th);
      const ny = s * Math.sin(th);
      const nz = Math.cos(ph);

      const scz = sphereCenterZ();

      // start ON the surface
      x[i] = sphereRad * nx;
      y[i] = sphereRad * ny;
      z[i] = scz + sphereRad * nz;

      // keep your "locked specks" behavior exactly as before
      const isLocked = Math.random() < lockRatio;
      locked[i] = isLocked ? 1 : 0;

      // ✅ CHANGE: emitted particles move OUTWARD from the surface (Test.astro vibe)
      if (isLocked) {
        vx[i] = 0;
        vy[i] = 0;
        vz[i] = 0;
      } else {
        // outward push along normal + tiny randomness so it breathes
        const base = driftVelocity * (0.85 + Math.random() * 0.35);
        vx[i] = base * nx + driftVelocity * 0.15 * randn();
        vy[i] = base * ny + driftVelocity * 0.15 * randn();
        vz[i] = base * nz + driftVelocity * 0.15 * randn();
      }

      age[i] = 0;
      stuck[i] = (50 + Math.random() * 30) | 0;

      alive[i] = 1;

      // Stable per-particle dissolve seed (Evervault-like threshold dissolve)
      dissolve[i] = Math.random();
    }

    function spawnSome(extra = 0) {
      // Base emission scales with --pulse (0..1)
      const p = getPulse();

      // 0.65..1.85 multiplier (tweak to taste)
      const mult = 0.65 + p * 1.2;

      const n = Math.max(0, ((particlesPerFrame * mult) | 0) + (extra | 0));

      for (let k = 0; k < n; k++) {
        const i = writeIndex;
        writeIndex = (writeIndex + 1) % N;
        resetParticle(i);
      }
    }

    for (let i = 0; i < Math.min(N, 1100); i++) resetParticle(i);

    // ---------- Test-like lifetime envelope ----------
    const attack = 50;
    const hold = 50;
    const decay = 100;
    const life = attack + hold + decay;

    // ---------- Render loop ----------
    let turnAngle = 0;
    let raf = 0;

    function beginFrame() {
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.imageSmoothingEnabled = true;
      ctx.imageSmoothingQuality = "high";

      ctx.globalCompositeOperation = "source-over";
      ctx.clearRect(0, 0, W, H);

      ctx.globalCompositeOperation = cachedMode;
      ctx.shadowBlur = 0;
      ctx.shadowColor = "transparent";
    }

    function endFrame() {
      ctx.globalCompositeOperation = "source-over";
      ctx.shadowBlur = 0;
      ctx.shadowColor = "transparent";
    }

    function draw() {
      if (document.hidden) {
        raf = 0;
        return;
      }

      // "Thump" burst when pulse crosses upward (optional but fun)
      const p = getPulse();
      const burst = lastPulse < 0.78 && p >= 0.78 ? 18 : 0; // tweak threshold + size
      lastPulse = p;

      const now = performance.now();
      updateVisibilityScore(now);

      // If the item is basically invisible, render less often.
      if (visScore <= 0.01) {
        raf = requestAnimationFrame(draw);
        return;
      }

      spawnSome(burst);

      const dl = disLevel(now); // 0..1 when disintegrating

      turnAngle = (turnAngle + turnSpeed) % (Math.PI * 2);
      const sinA = Math.sin(turnAngle);
      const cosA = Math.cos(turnAngle);

      beginFrame();

      const scz = sphereCenterZ();
      const inv2pi = 1 / (Math.PI * 2);

      const projCenterX = W / 2;
      const projCenterY = H / 2;

      for (let i = 0; i < N; i++) {
        if (!alive[i]) continue;

        age[i]++;

        // Test.astro: recycle particles after envelope completes
        if (age[i] > life) {
          resetParticle(i);
          continue;
        }

        // Test.astro: alpha envelope (attack/hold/decay)
        let pAlpha = 1;
        if (age[i] < attack) pAlpha = age[i] / attack;
        else if (age[i] < attack + hold) pAlpha = 1;
        else pAlpha = 1 - (age[i] - attack - hold) / decay;
        if (pAlpha <= 0) {
          resetParticle(i);
          continue;
        }

        if (dl > 0 && !locked[i]) {
          const dx = x[i];
          const dy = y[i];
          const dz = z[i] - scz;

          const r = Math.sqrt(dx * dx + dy * dy + dz * dz) || 1;
          const nx = dx / r;
          const ny = dy / r;
          const nz = dz / r;

          if (dis.mode === "in") {
            const kick = (0.08 + dl * 0.42) * driftVelocity;
            const dr = r - sphereRad;
            vx[i] += -nx * kick - nx * dr * 0.00085;
            vy[i] += -ny * kick - ny * dr * 0.00085;
            vz[i] += -nz * kick - nz * dr * 0.00085;
          } else {
            const kick = (0.1 + dl * 0.55) * driftVelocity;
            vx[i] += nx * kick;
            vy[i] += ny * kick;
            vz[i] += nz * kick;

            vx[i] += driftJitter * 2.2 * randn();
            vy[i] += driftJitter * 2.2 * randn();
            vz[i] += driftJitter * 2.2 * randn();
          }

          if (dis.mode === "in" && Math.abs(r - sphereRad) < 2.25) {
            locked[i] = 1;
          }
        }

        if (!locked[i] && age[i] > stuck[i]) {
          // emitted motion: outward + jitter, no re-projection to the sphere
          vx[i] += driftJitter * randn();
          vy[i] += driftJitter * randn() + gravity;
          vz[i] += driftJitter * randn();

          vx[i] *= damping;
          vy[i] *= damping;
          vz[i] *= damping;

          x[i] += vx[i];
          y[i] += vy[i];
          z[i] += vz[i];

          if (
            !Number.isFinite(x[i]) ||
            !Number.isFinite(y[i]) ||
            !Number.isFinite(z[i])
          ) {
            resetParticle(i);
            continue;
          }
        }

        const rotX = cosA * x[i] + sinA * (z[i] - scz);
        const rotZ = -sinA * x[i] + cosA * (z[i] - scz) + scz;

        const denom = fLen - rotZ;
        if (denom < nearPlaneEpsilon || rotZ > zMax) continue;

        const m = (radiusSp * fLen * projectionScale) / denom;
        if (!(m > 0 && m < 10)) continue;

        const px = rotX * m + projCenterX;
        const py = y[i] * m + projCenterY;
        if (px < -2 || px > W + 2 || py < -2 || py > H + 2) continue;

        let depth = 1 - rotZ / -750;
        depth = depth < 0 ? 0 : depth > 1 ? 1 : depth;

        const u = theta[i] * inv2pi + turnAngle * inv2pi;
        const v = phi[i] / Math.PI;

        const tex = sampleTexture(u, v);

        let rgb = fallbackRGB;
        let texA = 1;

        if (tex) {
          rgb = `${tex.r},${tex.g},${tex.b}`;
          texA = Math.max(0.5, tex.a);
        }

        // Evervault-like dissolve: speckled disappearance with a soft threshold band.
        // dl: 0..1, higher = more disintegrated.
        const band = 0.12;
        const k = (1 - dl - dissolve[i]) / band;
        const vis = k <= 0 ? 0 : k >= 1 ? 1 : k * k * (3 - 2 * k);
        if (vis <= 0) continue;

        const fade = 1 - dl;
        const a = Math.min(
          1,
          Math.max(0.1, depth * texA * materialStrength * fade * pAlpha * vis),
        );

        ctx.fillStyle = `rgba(${rgb}, ${a})`;
        ctx.beginPath();
        ctx.arc(px, py, m * particleRad, 0, Math.PI * 2);
        ctx.fill();
      }

      endFrame();
      raf = requestAnimationFrame(draw);
    }

    if (!reduceMotion) draw();

    window.addEventListener(
      "astro:before-swap",
      () => {
        cancelAnimationFrame(raf);
        clearInterval(pulseTimer);
        moTheme.disconnect();
        ro.disconnect();
        window.removeEventListener("nelumbo:scan", onScan);
        window.__orbMounted.delete(uid);
      },
      { once: true },
    );
  })();
</script>

<style>
  .ps-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    color: inherit;

    border-radius: 50%;
    overflow: hidden;

    transform: translateZ(0);
    backface-visibility: hidden;
  }

  canvas {
    width: 100%;
    height: 100%;
    display: block;
    background: transparent;
    border-radius: 50%;
  }

  :global(html.dark) {
    --ps-composite-mode: lighter;
    --ps-glow: off;
  }

  :global(html.light) {
    --ps-composite-mode: multiply;
    --ps-glow: off;
  }
</style>
