    (function waitForAse() {
      const s = window.__ase;
      if (!s) return requestAnimationFrame(waitForAse);
      startHud(s);
    })();

    function startHud(s) {
      const $ = (id) => document.getElementById(id);
      const clamp01 = (v) => Math.max(0, Math.min(1, v));
      const lerp = (a, b, t) => a + (b - a) * t;

      const hud = $("ase-debug");
      const moodEl = $("ase-mood");
      const spark = $("ase-spark");
      const vectorRadar = $("ase-vector-radar");
      const ctx = spark ? spark.getContext("2d") : null;
      const vectorCtx = vectorRadar ? vectorRadar.getContext("2d") : null;

      // ---------- Enhanced toggles ----------
      const state = {
        hidden: false, // Start visible by default
        s1: false,
        s2: false,
        s3: false,
        s4: false,
        s5: false,
        s6: false,
      };
      const apply = () => {
        hud.style.display = state.hidden ? "none" : "";
        ["s1", "s2", "s3", "s4", "s5", "s6"].forEach((k) => {
          const sec = $(`ase-${k}`);
          if (sec) sec.style.display = state[k] ? "" : "none";
          
          // Update button active state
          const btn = hud.querySelector(`[data-ase-toggle="${k}"]`);
          if (btn) {
            btn.setAttribute('data-active', state[k].toString());
          }
        });
        
        // Update main toggle button state
        const mainBtn = hud.querySelector(`[data-ase-toggle="all"]`);
        if (mainBtn) {
          mainBtn.setAttribute('data-active', (!state.hidden).toString());
        }
      };

      const bindToggle = (key) => {
        const btn = hud.querySelector(`[data-ase-toggle="${key}"]`);
        if (!btn) return;
        btn.addEventListener("click", () => {
          if (key === "all") state.hidden = !state.hidden;
          else state[key] = !state[key];
          apply();
        });
      };
      ["all", "s1", "s2", "s3", "s4", "s5", "s6"].forEach(bindToggle);
      apply();

      // keyboard shortcuts (E, 1-6)
      window.addEventListener("keydown", (e) => {
        const tag = document.activeElement?.tagName;
        if (tag === "INPUT" || tag === "TEXTAREA") return;

        if (e.key === "e" || e.key === "E") {
          state.hidden = !state.hidden;
          apply();
        }
        if (["1", "2", "3", "4", "5", "6"].includes(e.key)) {
          const k = `s${e.key}`;
          state[k] = !state[k];
          apply();
        }
      });

      // manual log
      const logBtn = $("ase-log-now");
      if (logBtn) {
        logBtn.addEventListener("click", () => {
          if (window.__ase && window.__ase.logSession) {
            window.__ase.logSession();
            logBtn.textContent = "✓";
            logBtn.disabled = true;
            setTimeout(() => {
              logBtn.textContent = "⏹";
              logBtn.disabled = false;
            }, 2000);
          }
        });
      }

      // manual training trigger
      const trainBtn = $("ase-train-now");
      if (trainBtn) {
        trainBtn.addEventListener("click", async () => {
          trainBtn.textContent = "🔄";
          trainBtn.disabled = true;
          
          try {
            const res = await fetch("http://localhost:8000/train", { method: "POST" });
            const result = await res.json();
            trainBtn.textContent = result.status === "success" ? "✅" : "❌";
          } catch (e) {
            trainBtn.textContent = "❌";
          }
          
          setTimeout(() => {
            trainBtn.textContent = "🧠";
            trainBtn.disabled = false;
          }, 3000);
        });
      }

      // ---------- Enhanced sparkline ----------
      const HISTORY = 60;
      const wakeHist = [];
      let smoothWake = 0.5;

      function drawSpark() {
        if (!ctx || wakeHist.length < 2) return;
        const w = spark.width, h = spark.height;
        ctx.clearRect(0, 0, w, h);
        ctx.beginPath();
        for (let i = 0; i < wakeHist.length; i++) {
          const x = (i / (HISTORY - 1)) * w;
          const y = h - clamp01(wakeHist[i]) * (h - 2) - 1;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = "rgba(170,135,255,0.95)";
        ctx.lineWidth = 2;
        ctx.stroke();
      }

      // ---------- Radar visualization ----------
      function drawRadar(ctx, values, size = 40) {
        if (!ctx) return;
        const centerX = size;
        const centerY = size;
        const radius = size - 10;
        const angleStep = (Math.PI * 2) / values.length;

        ctx.clearRect(0, 0, size * 2, size * 2);
        
        // Draw grid
        ctx.strokeStyle = "rgba(255,255,255,0.1)";
        ctx.lineWidth = 1;
        for (let i = 1; i <= 5; i++) {
          ctx.beginPath();
          ctx.arc(centerX, centerY, (radius * i) / 5, 0, Math.PI * 2);
          ctx.stroke();
        }

        // Draw axes
        for (let i = 0; i < values.length; i++) {
          const angle = i * angleStep - Math.PI / 2;
          ctx.beginPath();
          ctx.moveTo(centerX, centerY);
          ctx.lineTo(
            centerX + Math.cos(angle) * radius,
            centerY + Math.sin(angle) * radius
          );
          ctx.stroke();
        }

        // Draw data
        ctx.fillStyle = "rgba(170,135,255,0.3)";
        ctx.strokeStyle = "rgba(170,135,255,0.8)";
        ctx.lineWidth = 2;
        ctx.beginPath();
        for (let i = 0; i < values.length; i++) {
          const angle = i * angleStep - Math.PI / 2;
          const value = clamp01(values[i]);
          const x = centerX + Math.cos(angle) * radius * value;
          const y = centerY + Math.sin(angle) * radius * value;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.closePath();
        ctx.fill();
        ctx.stroke();
